# .env.example — copy to .env.local for development
# NEVER commit the actual .env file to git

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/pizzakhanum?retryWrites=true&w=majority

# ── Auth (SERVER SIDE ONLY — no VITE_ prefix, never sent to browser) ─────────
# SECURITY: Replace VITE_ADMIN_PASSWORD with this. The old approach exposed
# the password to anyone who opened DevTools → Sources.
ADMIN_PASSWORD=your-strong-admin-password-here

# ── JWT signing secret (generate with: openssl rand -hex 32) ─────────────────
JWT_SECRET=replace-with-a-64-char-random-hex-string

# ── App origin (tighten CORS in production) ───────────────────────────────────
# APP_ORIGIN=https://pizzakhanum.vercel.app

# ── Cloudinary (VITE_ prefix = safe to expose to browser) ────────────────────
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# ── REMOVED: Never add this again ─────────────────────────────────────────────
# VITE_ADMIN_PASSWORD=...   ← THIS WAS THE SECURITY BUG. Removed permanently.
